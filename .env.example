# ==============================================================================
# LINGT FOUNDATIONAL ENVIRONMENT VARIABLES
# Copy this file to '.env.local' for local development.
# ==============================================================================

# 1. CORE WEB HOOKS
# APP_URL: The URL where this applet is hosted (e.g., https://my-app.run.app).
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 2. GEMINI AI CLIENT
# GOOGLE_API_KEY is preferred by the LangChain Google integration.
# GEMINI_API_KEY is also supported by LingT as an alias.
# Keep this secret server-side to avoid leaking credentials to client browsers.
GOOGLE_API_KEY="YOUR_GOOGLE_AI_STUDIO_API_KEY"
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GEMINI_MODEL="gemini-3.5-flash"
# Use "gcp" when the key was created from Google Cloud / Vertex AI Express / Agent Platform.
# Leave empty or remove when using a Google AI Studio API key.
GOOGLE_PLATFORM_TYPE=""

# 3. FIREBASE INTEGRATION (FIRESTORE & AUTHENTICATION)
# Required when scaling to durable cloud persistence.
NEXT_PUBLIC_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-app-id.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-app-id.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-messaging-id"
NEXT_PUBLIC_FIREBASE_APP_ID="your-app-id"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="your-measurement-id"
NEXT_PUBLIC_FIREBASE_VAPID_KEY="your-web-push-vapid-key"

# Required for server routes that must bypass Firestore client rules safely.
# Use either FIREBASE_SERVICE_ACCOUNT_JSON, or the three split values below.
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_SERVICE_ACCOUNT_JSON='{"project_id":"...","client_email":"...","private_key":"..."}'

# 4. GOOGLE OAUTH CLIENT (GOOGLE CALENDAR INTEGRATION)
# Required to fetch calendar items and execute auto-rescheduling escalations.
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/integrations/google/callback"
GOOGLE_OAUTH_STATE_SECRET="replace-with-a-random-state-signing-secret"

# 5. GMAIL AGENT WEBHOOK + CALENDAR AUTOMATION
# Apps Script sends incoming Gmail snippets to /api/gmail/webhook with this shared secret.
GMAIL_WEBHOOK_SECRET="replace-with-a-random-webhook-secret"
# Keep false by default. Set true only for a consented demo/prod environment.
LINGT_AUTOCOMMIT_CALENDAR="false"
REMINDER_CRON_SECRET="replace-with-a-random-cron-secret"
